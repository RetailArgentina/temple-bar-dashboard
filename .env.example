# =============================================================================
# .env.example — Copy to .env.local and fill in values for local development
#
# For Cloud Run production, these are set via:
#   - gcloud run deploy --set-env-vars (non-secret)
#   - gcloud run deploy --update-secrets (secret values)
# =============================================================================

# ---------------------------------------------------------------------------
# Required — must be set before the app will start
# ---------------------------------------------------------------------------

# Flask session signing key (generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
# In production: stored in Secret Manager as 'flask-secret-key'
FLASK_SECRET_KEY=your-flask-secret-key-here

# Google OAuth 2.0 credentials
# Create at: https://console.cloud.google.com/apis/credentials
OAUTH_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
# In production: stored in Secret Manager as 'oauth-client-secret'
OAUTH_CLIENT_SECRET=your-oauth-client-secret-here

# GCS bucket for dashboard data cache
CACHE_BUCKET=temple-bar-dashboard-cache

# ---------------------------------------------------------------------------
# Optional — defaults are shown
# ---------------------------------------------------------------------------

# GCP project and BigQuery dataset
GCP_PROJECT_ID=temple-bar-439715
BQ_DATASET_ID=temple_bar

# Service account email that Cloud Scheduler uses to invoke /api/refresh
# Must match the OIDC token email in the require_scheduler decorator
SCHEDULER_SA_EMAIL=scheduler-invoker@temple-bar-439715.iam.gserviceaccount.com

# Cloud Run service URL — REQUIRED for /api/refresh OIDC verification
# Set this AFTER first deploy when the URL is known.
# If empty, /api/refresh returns 503 (safe — prevents audience-less token verification)
# Format: https://temple-bar-dashboard-HASH-uc.a.run.app (no trailing slash)
CLOUD_RUN_URL=
