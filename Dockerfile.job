FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONIOENCODING=utf-8

WORKDIR /app

COPY requirements_job.txt .
RUN pip install --no-cache-dir -r requirements_job.txt

COPY *.py ./
COPY templates/ ./templates/

CMD ["python", "-X", "utf8", "actualizar_todo.py"]
